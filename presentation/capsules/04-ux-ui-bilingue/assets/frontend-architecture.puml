@startuml
skinparam classAttributeIconSize 0

package "Bootstrap" {
  class main_ts as "main.ts\nbootstrapApplication()"
  class app_config as "app.config.ts"
  class app_routes as "app.routes.ts"
}

package "Interceptors" {
  class AuthInterceptor
  class AuthRefreshInterceptor
  class ErrorInterceptor
}

package "Core Services" {
  class ApiService
  class AuthService
  class RealtimeService
  class ProgressService
  class PlayerService
  class LibraryService
  class DiscussionService
}

package "Feature Pages" {
  class LoginPage
  class RegisterPage
  class LibraryPage
  class PlayerPage
  class DiscussionsPage
  class ProfilePage
  class AdminShell
}

main_ts --> app_config
app_config --> app_routes
app_config --> AuthInterceptor
app_config --> AuthRefreshInterceptor
app_config --> ErrorInterceptor

AuthInterceptor --> AuthService
AuthRefreshInterceptor --> AuthService

LibraryPage --> LibraryService
PlayerPage --> PlayerService
DiscussionsPage --> DiscussionService
LoginPage --> AuthService
RegisterPage --> AuthService

AuthService --> ApiService
LibraryService --> ApiService
DiscussionService --> ApiService
ProgressService --> ApiService
PlayerService --> ApiService
PlayerService --> ProgressService
PlayerService --> RealtimeService

RealtimeService --> "WebSocket /ws"
ApiService --> "HTTP /api/v1 + /streaming"
@enduml
