@startuml
skinparam classAttributeIconSize 0

package "Worker Core" {
  class worker_ts as "worker.ts\nstartWorker()"
  class JobRunner
  class JobProcessor
  class WorkerSettingsService
  class ParitySchedulerService
  class TagSyncSchedulerService
}

package "Job Handlers" {
  class IngestJob as "ingest.job.ts"
  class IngestMp3Job as "ingest-mp3-as-m4b.job.ts"
  class SanitizeJob as "sanitize-mp3.job.ts"
  class WriteMetadataJob as "write-metadata.job.ts"
  class ReplaceFileJob as "replace-file.job.ts"
  class ReplaceCoverJob as "replace-cover.job.ts"
  class ExtractCoverJob as "extract-cover.job.ts"
  class RescanJob as "rescan.job.ts"
  class SyncTagsJob as "sync-tags.job.ts"
  class DeleteBookJob as "delete-book.job.ts"
}

package "Worker Services" {
  class FFmpegService
  class FileService
  class MetadataService
  class MP3MetadataService
  class ChecksumService
}

package "Persistence" {
  class JobModel
  class BookCollection as "books collection"
}

worker_ts --> JobRunner
worker_ts --> ParitySchedulerService
worker_ts --> TagSyncSchedulerService

JobRunner --> WorkerSettingsService
JobRunner --> JobProcessor
JobProcessor --> WorkerSettingsService
JobProcessor --> JobModel

JobProcessor --> IngestJob
JobProcessor --> IngestMp3Job
JobProcessor --> SanitizeJob
JobProcessor --> WriteMetadataJob
JobProcessor --> ReplaceFileJob
JobProcessor --> ReplaceCoverJob
JobProcessor --> ExtractCoverJob
JobProcessor --> RescanJob
JobProcessor --> SyncTagsJob
JobProcessor --> DeleteBookJob

IngestJob --> FFmpegService
IngestJob --> FileService
IngestJob --> MetadataService
IngestJob --> ChecksumService

IngestMp3Job --> FFmpegService
IngestMp3Job --> FileService
IngestMp3Job --> MP3MetadataService
IngestMp3Job --> ChecksumService
IngestMp3Job --> BookCollection
IngestMp3Job --> JobModel

SanitizeJob --> FFmpegService
SanitizeJob --> MetadataService
SanitizeJob --> FileService
SanitizeJob --> ChecksumService
SanitizeJob --> BookCollection
@enduml
