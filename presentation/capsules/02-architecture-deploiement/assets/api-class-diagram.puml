@startuml
skinparam classAttributeIconSize 0

package "API Bootstrap" {
  class server_ts as "server.ts\nstart()"
  class app_ts as "app.ts\ncreateApp()"
}

package "Middlewares" {
  class AuthMiddleware
  class RoleMiddleware
  class RateLimitMiddleware
  class StreamAuthMiddleware
  class ErrorMiddleware
}

package "Controllers" {
  class AuthController
  class BookController
  class ProgressController
  class StreamingController
  class AdminController
  class JobController
  class DiscussionController
}

package "Services" {
  class AuthService
  class BookService
  class ProgressService
  class StreamingService
  class JobService
  class DiscussionService
}

package "Realtime" {
  class RealtimeGateway
  class RealtimeEvents {
    +subscribeRealtimeEvents(listener)
    +emitRealtimeEvent(type, payload)
  }
}

package "Models" {
  class UserModel
  class AuthSessionModel
  class BookModel
  class ProgressModel
  class JobModel
}

server_ts --> app_ts
server_ts --> RealtimeGateway
app_ts --> AuthMiddleware
app_ts --> RoleMiddleware
app_ts --> RateLimitMiddleware
app_ts --> StreamAuthMiddleware
app_ts --> ErrorMiddleware

app_ts --> AuthController
app_ts --> BookController
app_ts --> ProgressController
app_ts --> StreamingController
app_ts --> AdminController
app_ts --> JobController
app_ts --> DiscussionController

AuthController --> AuthService
BookController --> BookService
ProgressController --> ProgressService
StreamingController --> StreamingService
AdminController --> JobService
JobController --> JobService
DiscussionController --> DiscussionService

AuthService --> UserModel
AuthService --> AuthSessionModel
BookService --> BookModel
ProgressService --> ProgressModel
ProgressService --> BookModel
StreamingService --> BookModel
StreamingService --> ProgressModel
JobService --> JobModel

ProgressService --> RealtimeEvents
DiscussionService --> RealtimeEvents
RealtimeGateway --> RealtimeEvents
@enduml
