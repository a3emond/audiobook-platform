# =========================
# GLOBAL
# =========================
NODE_ENV=development

# =========================
# API
# =========================
API_PORT=3000
JWT_SECRET=supersecret
JWT_EXPIRES_IN=12h
REFRESH_TOKEN_DAYS=60
BCRYPT_ROUNDS=12
UPLOAD_MAX_FILE_SIZE_BYTES=2147483648

# Optional one-time bootstrap admin user. If both values are set,
# the API will create/promote this account as admin on startup.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_DISPLAY_NAME=
INITIAL_ADMIN_LOCALE=en

# OAuth audience configuration
# Use *_IDS for multi-platform clients (comma-separated).
# If *_IDS is set, it takes precedence over *_ID.
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=

# Backward-compatible single audience (optional if *_IDS is set)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# =========================
# WORKER QUEUE
# =========================
# Job polling interval in milliseconds
WORKER_POLL_MS=1500

# How long to keep job logs in MongoDB before auto-deletion (days)
# Keep this low — jobLogs can grow quickly with high ingestion volume
JOB_LOG_RETENTION_DAYS=15

# Number of concurrent job workers per instance
WORKER_CONCURRENCY=1

# Optional worker ID; auto-generated if not set
# WORKER_ID=

# Job retry backoff settings (milliseconds)
WORKER_RETRY_BASE_MS=2000
WORKER_RETRY_MAX_MS=60000

# =========================
# DB
# =========================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_DB=audiobook

MONGO_URI=mongodb://admin:password@db:27017/audiobook?authSource=admin

# =========================
# STORAGE
# =========================
AUDIOBOOKS_PATH=/data/audiobooks

# =========================
# FRONTEND
# =========================
FRONTEND_PORT=4200

# Comma-separated list of allowed origins for API CORS.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:8100,https://audiobook.aedev.pro

CORS_ALLOWED_ORIGINS=https://audiobook.aedev.pro,http://localhost:8100,http://127.0.0.1:8100

# OAuth client IDs exposed to the Angular app at runtime via env.js.
# These are PUBLIC values (not secrets). Leave empty to disable the OAuth buttons.
# The nginx container must receive these as env vars to inject them into env.js.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# FFmpeg execution limits (increase for long MP3 -> M4B conversions)
FFMPEG_TIMEOUT_MS=300000
FFMPEG_LONG_TIMEOUT_MS=3600000
FFMPEG_MAX_BUFFER_BYTES=52428800

# Defer heavy jobs (MP3->M4B / large repacks) by this many ms to avoid peak-hour saturation
HEAVY_JOB_DELAY_MS=0

# DB-seeded defaults for worker heavy-job policy (used when worker_settings is absent)
HEAVY_JOB_TYPES=SANITIZE_MP3_TO_M4B,REPLACE_FILE
HEAVY_JOB_WINDOW_ENABLED=false
HEAVY_JOB_WINDOW_START=03:00
HEAVY_JOB_WINDOW_END=05:00

# How often API/worker refresh DB-backed worker settings cache
WORKER_SETTINGS_CACHE_TTL_MS=15000
WORKER_SETTINGS_REFRESH_MS=15000




# =========================
# PROD ENV EXAMPLE FOR REFERENCE
# =========================

# NODE_ENV=production
# API_PORT=3000

# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=password
# MONGO_DB=audiobook

# MONGO_URI=mongodb://admin:password@db:27017/audiobook?authSource=admin

# AUDIOBOOKS_PATH=/data/audiobooks

# JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
# JWT_EXPIRES_IN=12h
# REFRESH_TOKEN_DAYS=60
# BCRYPT_ROUNDS=12

# CORS_ALLOWED_ORIGINS=https://audiobook.aedev.pro

# GOOGLE_CLIENT_IDS=YOUR_WEB_GOOGLE_CLIENT_ID,YOUR_IOS_GOOGLE_CLIENT_ID,YOUR_ANDROID_GOOGLE_CLIENT_ID
# APPLE_CLIENT_IDS=YOUR_WEB_APPLE_SERVICE_ID,YOUR_IOS_BUNDLE_ID,YOUR_MACOS_BUNDLE_ID
